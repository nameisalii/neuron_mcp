# Neuron environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/neuron

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Pinecone vector database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index_name

# Slack integration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token

# Notion OAuth integration
NOTION_CLIENT_ID=your_notion_oauth_client_id
NOTION_CLIENT_SECRET=your_notion_oauth_client_secret
# OAuth redirect URI:
# Local: http://localhost:3000/api/integrations/notion/callback
# Production: https://app.tryneuron.net/api/integrations/notion/callback

# Gmail integration (OAuth)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# OAuth redirect URI:
# Local: http://localhost:3000/api/integrations/gmail/callback
# Production: https://tryneuron.net/api/integrations/gmail/callback

# Linear integration (OAuth)
LINEAR_CLIENT_ID=your_linear_oauth_client_id
LINEAR_CLIENT_SECRET=your_linear_oauth_client_secret
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENCRYPTION_KEY=64_hex_chars_generate_with_openssl_rand_hex_32
CRON_SECRET=generate_a_long_random_string

# Neuron API / MCP server
NEURON_API_KEY=your_neuron_api_key
NEURON_API_URL=http://localhost:3000
NEURON_WORKSPACE_ID=your_workspace_id

# Optional services
HF_TOKEN=hf_your_huggingface_token
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key
