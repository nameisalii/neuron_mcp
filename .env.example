# Neuron environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Product URL
# Production: https://app.tryneuron.net
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://app.tryneuron.net

# Database (Prisma)
DATABASE_URL=postgresql://user:password@host:5432/neuron
# DIRECT_URL=postgresql://user:password@host:5432/neuron

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard/overview
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key

# Pinecone vector database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index_name

# Slack integration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token

# Notion OAuth integration
NOTION_CLIENT_ID=your_notion_oauth_client_id
NOTION_CLIENT_SECRET=your_notion_oauth_client_secret
# OAuth redirect URI:
# Local: http://localhost:3000/api/integrations/notion/callback
# Production: https://app.tryneuron.net/api/integrations/notion/callback

# Gmail integration (OAuth)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# OAuth redirect URI:
# Local: http://localhost:3000/api/integrations/gmail/callback
# Production: https://app.tryneuron.net/api/integrations/gmail/callback

# Linear integration (OAuth)
LINEAR_CLIENT_ID=your_linear_oauth_client_id
LINEAR_CLIENT_SECRET=your_linear_oauth_client_secret
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret
# Production OAuth callback: https://app.tryneuron.net/api/integrations/linear/callback
# Production webhook: https://app.tryneuron.net/api/integrations/linear/webhook

# Discord integration (OAuth bot install) — OPTIONAL.
# If these are unset the app still builds and runs; only the Discord
# connect/sync routes report "Discord is not configured".
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
# Local: http://localhost:3000/api/integrations/discord/callback
# Production: https://app.tryneuron.net/api/integrations/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/integrations/discord/callback

# Granola integration — no app-level env vars required.
# Each user pastes their own personal API key (grn_...) in the Granola card;
# it is encrypted with ENCRYPTION_KEY and stored per workspace.

# WhatsApp Business Cloud API integration — OPTIONAL.
# Users paste their Meta access token and phone number ID in the WhatsApp card.
# Configure the Meta webhook callback to:
# Local: http://localhost:3000/api/integrations/whatsapp/webhook
# Production: https://app.tryneuron.net/api/integrations/whatsapp/webhook
WHATSAPP_VERIFY_TOKEN=generate_a_long_random_string
# Optional but recommended: verifies X-Hub-Signature-256 on webhook POSTs.
WHATSAPP_APP_SECRET=

# Telegram Bot API integration — OPTIONAL.
# The webhook URL must be public HTTPS in production or an HTTPS tunnel locally.
# Missing values do not prevent the app from starting.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_BOT_USERNAME=neuron_mcp_bot

# Microsoft Teams integration via official Microsoft Graph APIs — OPTIONAL.
# Local redirect: http://localhost:3000/api/integrations/teams/callback
# Production redirect: https://app.tryneuron.net/api/integrations/teams/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/teams/callback
MICROSOFT_TEAMS_WEBHOOK_CLIENT_STATE=

# Jira Cloud integration via official Atlassian OAuth 2.0 3LO — OPTIONAL.
# Local redirect: http://localhost:3000/api/integrations/jira/callback
# Production redirect: https://app.tryneuron.net/api/integrations/jira/callback
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:3000/api/integrations/jira/callback

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Security and scheduled jobs
ENCRYPTION_KEY=64_hex_chars_generate_with_openssl_rand_hex_32
CRON_SECRET=generate_a_long_random_string

# Neuron API / MCP server
NEURON_API_KEY=your_neuron_api_key
NEURON_API_URL=https://app.tryneuron.net
NEURON_WORKSPACE_ID=your_workspace_id

# Optional services
HF_TOKEN=hf_your_huggingface_token
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key
