datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String     @id @default(cuid())
  clerkId         String     @unique
  email           String     @unique
  name            String?
  workspaceType        String     @default("PERSONAL")
  week1ReportSent      Boolean    @default(false)
  week1SentAt          DateTime?
  onboardingCompleted  Boolean    @default(false)
  createdAt            DateTime   @default(now())
  workspace       Workspace?
}

model Workspace {
  id             String             @id @default(cuid())
  name           String?
  type           String             @default("solo")
  ownerId        String             @unique
  owner          User               @relation(fields: [ownerId], references: [id])
  iconUrl        String?
  plan           String             @default("free")
  knowledgeItems KnowledgeItem[]
  decisions      Decision[]
  ideas          Idea[]
  clients        Client[]
  integrations   Integration[]
  notionPages    NotionPage[]
  members        WorkspaceMember[]
  invitations    Invitation[]
  activityEvents ActivityEvent[]
  queryLogs      QueryLog[]
  captureRules   CaptureRule[]
  captureLogs    CaptureLog[]
  syncStatuses   SyncStatus[]
  digests        Digest[]
  alerts         Alert[]
  userPreferences UserPreference[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt
}

model KnowledgeItem {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content      String
  category     String
  source       String
  sourceUrl    String?
  owner        String?
  verified     Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedBy   String?
  confidence   Float     @default(0.8)
  embeddingId  String?
  frozen       Boolean   @default(false)
  conflictNote String?
  reason       String?
  alternatives String?
  contentHash      String?
  clientId         String?
  client           Client?     @relation(fields: [clientId], references: [id])
  label            String?
  notionPageId     String?
  notionPage       NotionPage? @relation(fields: [notionPageId], references: [id])
  notionPageTitle  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([workspaceId, contentHash])
  @@index([workspaceId, category])
  @@index([workspaceId, verified])
  @@index([workspaceId, notionPageId])
}

model Decision {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  decision    String
  alternatives String?
  reason      String?
  source      String
  sourceUrl   String?
  madeBy      String?
  madeAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model Idea {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     String
  source      String
  relatedIds  String[]
  actionedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model Client {
  id             String          @id @default(cuid())
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  knowledgeItems KnowledgeItem[]
  createdAt      DateTime        @default(now())
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  role        String    @default("member")
  displayName String
  avatarUrl   String?
  department  String?
  joinedAt    DateTime  @default(now())
  invitedBy   String?
  status      String    @default("active")

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invitation {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("member")
  invitedBy   String
  status      String    @default("pending")
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([token])
}

model Integration {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String
  accessToken String
  botUserId   String?
  teamId      String?
  teamName    String?
  channels    String[]
  metadata    Json?
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, type])
}

model NotionPage {
  id             String          @id @default(cuid())
  notionPageId   String
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String
  parentPageId   String?
  content        String
  blockStructure Json
  iconUrl        String?
  lastEditedAt   DateTime
  syncedBy       String?
  syncedAt       DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  chunks         NotionChunk[]
  knowledgeItems KnowledgeItem[]

  @@unique([workspaceId, notionPageId])
  @@index([workspaceId])
  @@index([parentPageId])
}

model NotionChunk {
  id              String     @id @default(cuid())
  notionPageId    String
  page            NotionPage @relation(fields: [notionPageId], references: [id], onDelete: Cascade)
  workspaceId     String
  content         String
  blockType       String
  position        Int
  metadata        Json?
  pineconeId      String?
  labels          Json       @default("[]")
  labeledBy       Json       @default("[]")
  visibility      String     @default("team")
  visibilitySetBy String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([notionPageId])
  @@index([workspaceId])
  @@index([workspaceId, visibility])
}

model ActivityEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  displayName String
  eventType   String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([userId])
}

model QueryLog {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId         String
  displayName    String
  query          String
  answer         String
  sourceChunkIds Json     @default("[]")
  createdAt      DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
}

model CaptureRule {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration String       // "notion" | "slack"
  ruleType    String       // "include" | "exclude"
  target      String       // pageId, channelId, or keyword pattern
  targetName  String       // human-readable label
  createdBy   String       // Clerk userId — attribution
  createdAt   DateTime     @default(now())
  captureLogs CaptureLog[]

  @@index([workspaceId])
  @@index([workspaceId, integration])
}

model CaptureLog {
  id             String       @id @default(cuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  timestamp      DateTime     @default(now())
  source         String       // "notion" | "slack"
  sourceId       String       // pageId or channelId
  contentPreview String       // first 50 chars
  status         String       // "captured" | "skipped" | "excluded"
  reason         String
  captureRuleId  String?
  captureRule    CaptureRule? @relation(fields: [captureRuleId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, timestamp])
  @@index([workspaceId, source])
  @@index([workspaceId, status])
}

model SyncStatus {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  integration  String    // "notion" | "slack"
  mode         String    @default("manual")  // "manual" | "background"
  lastSyncAt   DateTime?
  nextSyncAt   DateTime?
  status       String    @default("active")  // "active" | "paused" | "error"
  errorMessage String?
  configuredBy String    // Clerk userId — attribution

  @@unique([workspaceId, integration])
  @@index([workspaceId])
  @@index([integration, mode, status])
}

model UserPreference {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId             String    // Clerk userId
  focusAreas         Json      @default("[]")
  digestEnabled      Boolean   @default(true)
  digestTime         Int       @default(8)  // UTC hour 0–23
  emailDigest        Boolean   @default(false)
  alertsEnabled      Boolean   @default(true)
  staleThresholdDays Int       @default(30)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
}

model Digest {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    // Clerk userId
  date        DateTime  // calendar date this digest covers
  content     Json      // { summary, highlights, stats }
  type        String    // "daily" | "weekly"
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, userId, type])
}

model Alert {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type           String    // "conflict" | "stale" | "important"
  title          String
  description    String
  sourceChunkIds Json      @default("[]")
  targetUserId   String?   // nullable — workspace-wide vs user-targeted
  status         String    @default("unread")  // "unread" | "read" | "resolved"
  resolvedBy     String?   // Clerk userId — ATTRIBUTION
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@index([targetUserId])
}
